300.000","autoResize":false,"lineHeight":1.25},{"type":"text","version":3214,"versionNonce":776088834,"index":"aH","isDeleted":false,"id":"KGa7BsxQ-Cy3JCGV_Xfwy","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":-786.4680365307838,"y":883.0978107670044,"strokeColor":"#b2f2bb","backgroundColor":"#6c2f01","width":95.29635650911322,"height":23.17919136143438,"seed":1019389314,"groupIds":["NsBhXCHdHPqdcqz_MqulF","b0Zo0Vxw4ZsdJLzscfW3I","D62T2dIdbd1Fhm8mr_58r"],"frameId":null,"roundness":null,"boundElements":[],"updated":1728321114504,"link":null,"locked":false,"fontSize":18.543353089147505,"fontFamily":8,"text":"Entonces:","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Entonces:","autoResize":false,"lineHeight":1.25},{"type":"text","version":3853,"versionNonce":1966685378,"index":"aI","isDeleted":false,"id":"AwFsRfsNLQjmPE1hYWqhQ","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":-675.9913763471704,"y":882.8796794683903,"strokeColor":"#ffffff","backgroundColor":"#6c2f01","width":349.57365322727816,"height":46.35838272286876,"seed":1041671490,"groupIds":["dkx1MXUfvxRJtMxnrEI5U","r8Bc4wKjYC_jXSQfyOaO8","b0Zo0Vxw4ZsdJLzscfW3I","D62T2dIdbd1Fhm8mr_58r"],"frameId":null,"roundness":null,"boundElements":[],"updated":1728321114504,"link":null,"locked":false,"fontSize":18.543353089147505,"fontFamily":8,"text":"el sistema almacena el tramite y \nimpmrime un numero de comprobante","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"el sistema almacena el tramite y impmrime un numero de comprobante","autoResize":false,"lineHeight":1.25},{"type":"text","version":138,"versionNonce":882892638,"index":"aJ","isDeleted":false,"id":"SuxqR_stOBk5GiuUyf4VP","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":-513.8232363039883,"y":-267.1915286850475,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":2504.0764811197914,"height":538.3333333333331,"seed":1012182274,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1728322168933,"link":null,"locked":false,"fontSize":22.66666666666666,"fontFamily":5,"text":"Problema 12: Créditos bancarios\nSe desea modelar mediante historias de usuario el manejo de créditos otorgados por un banco a sus clientes.\nLos clientes que desean pedir un crédito, deben iniciar un trámite a través de un sitio web del banco ingresando dni,\nnombre, apellido, mail, tipo de crédito (personal, vivienda, etc.) y monto solicitado. El sistema acepta el inicio de trámite\nsi el dni ingresado corresponde a un cliente del banco y si el crédito solicitado no supera los $400.000. En caso de que no\nsea cliente del banco el sistema deberá enviar un correo electrónico al email ingresado con un instructivo para hacerse\ncliente del banco. Si el monto supera los $400.000 el sistema rechaza el inicio de trámite y muestra el mensaje “El monto\nsolicitado excede el límite permitido”. Si los datos son correctos, el sistema almacena el trámite para que sea analizado\npor el área económica e imprime un número de comprobante para el cliente.\nPor otro lado, los clientes pueden consultar el estado de un trámite, para esto es necesario que se ingrese un número de\ncomprobante. Si el número de comprobante es válido, el sistema retorna un informe con el estado del mismo, de lo\ncontrario mostrará un mensaje “trámite inexistente”. Si el cliente ingresa tres veces un código inexistente el sistema\nbloquea la ip (dirección de red de la máquina que efectúa la consulta) del cliente por 24 horas mostrando un mensaje\n“Usted ha excedido el número de consultas inválidas”.\nPor último, el gerente del banco puede pedir un listado de créditos aprobados entre fechas. Si las fechas ingresadas son\nválidas, el sistema mostrará un listado con los créditos aprobados, de lo contrario mostrará un mensaje “las fechas\ningresadas no son válidas”. El sistema utiliza un sistema de autenticación general del banco, por lo que no es necesario\nmodelar el iniciar y cerrar sesión. Si no hay créditos aprobados para las fechas ingresadas el sistema mostrará el siguiente\nmensaje: ”No hay créditos aprobados en las fechas ingresadas”","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Problema 12: Créditos bancarios\nSe desea modelar mediante historias de usuario el manejo de créditos otorgados por un banco a sus clientes.\nLos clientes que desean pedir un crédito, deben iniciar un trámite a través de un sitio web del banco ingresando dni,\nnombre, apellido, mail, tipo de crédito (personal, vivienda, etc.) y monto solicitado. El sistema acepta el inicio de trámite\nsi el dni ingresado corresponde a un cliente del banco y si el crédito solicitado no supera los $400.000. En caso de que no\nsea cliente del banco el sistema deberá enviar un correo electrónico al email ingresado con un instructivo para hacerse\ncliente del banco. Si el monto supera los $400.000 el sistema rechaza el inicio de trámite y muestra el mensaje “El monto\nsolicitado excede el límite permitido”. Si los datos son correctos, el sistema almacena el trámite para que sea analizado\npor el área económica e imprime un número de comprobante para el cliente.\nPor otro lado, los clientes pueden consultar el estado de un trámite, para esto es necesario que se ingrese un número de\ncomprobante. Si el número de comprobante es válido, el sistema retorna un informe con el estado del mismo, de lo\ncontrario mostrará un mensaje “trámite inexistente”. Si el cliente ingresa tres veces un código inexistente el sistema\nbloquea la ip (dirección de red de la máquina que efectúa la consulta) del cliente por 24 horas mostrando un mensaje\n“Usted ha excedido el número de consultas inválidas”.\nPor último, el gerente del banco puede pedir un listado de créditos aprobados entre fechas. Si las fechas ingresadas son\nválidas, el sistema mostrará un listado con los créditos aprobados, de lo contrario mostrará un mensaje “las fechas\ningresadas no son válidas”. El sistema utiliza un sistema de autenticación general del banco, por lo que no es necesario\nmodelar el iniciar y cerrar sesión. Si no hay créditos aprobados para las fechas ingresadas el sistema mostrará el siguiente\nmensaje: ”No hay créditos aprobados en las fechas ingresadas”","autoResize":false,"lineHeight":1.25},{"type":"rectangle","version":56,"versionNonce":1827600130,"index":"aK","isDeleted":false,"id":"c43_fVlgrfB3pKdZJKDmi","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":-471.7849957440935,"y":-210.260435257695,"strokeColor":"#1971c2","backgroundColor":"transparent","width":93,"height":30,"seed":486259906,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1728321072434,"link":null,"locked":false},{"type":"rectangle","version":236,"versionNonce":398247618,"index":"aL","isDeleted":false,"id":"LW-OAORnAkp_Tth9Qd8E8","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":96.94227698317911,"y":-157.260435257695,"strokeColor":"#2f9e44","backgroundColor":"transparent","width":529.2727272727274,"height":32,"seed":1034605698,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1728321072434,"link":null,"locked":false},{"type":"rectangle","version":112,"versionNonce":263888514,"index":"aM","isDeleted":false,"id":"kTkJsMrZGpoTEsCBpXi-M","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":-524.7849957440935,"y":-182.260435257695,"strokeColor":"#f08c00","backgroundColor":"transparent","width":908,"height":25,"seed":1881207874,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1728321072434,"link":null,"locked":false},{"type":"rectangle","version":138,"versionNonce":1101495874,"index":"aN","isDeleted":false,"id":"ZWUVsTLi7zPGJeSv